; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Furlan Go"
config/description="Gioco AR location-based per Cividale del Friuli"
config/version="0.1.0"
run/main_scene="res://scenes/loading/loading_screen.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=2
window/stretch/mode="canvas_items"

[autoload]

MapManager="*res://scripts/map/map_manager.gd"
ARManager="*res://scripts/ar/ar_manager.gd"
GPSManager="*res://scripts/gps/gps_manager.gd"
PlayerLocationManager="*res://scripts/player/player_location_manager.gd"
GeofenceManager="*res://scripts/geofence/geofence_manager.gd"
CreatureSpawnManager="*res://scripts/creature/creature_spawn_manager.gd"
POIManager="*res://scripts/poi/poi_manager.gd"
PerformanceManager="*res://scripts/performance/performance_manager.gd"
SceneTransitionManager="*res://scripts/scene/scene_transition_manager.gd"
CaptureSystem="*res://scripts/capture/capture_system.gd"
BattleSystem="*res://scripts/battle/battle_system.gd"
CreatureProgressionSystem="*res://scripts/creature/creature_progression_system.gd"

[input]

ui_left={
"deadzone": 0.5,
