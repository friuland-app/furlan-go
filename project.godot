[layer_names]

2d_physics/layer_1="Player"
2d_physics/layer_2="Creature"
2d_physics/layer_3="POI"
2d_physics/layer_4="Environment"
2d_physics/layer_5="UI"

2d_render/layer_1="Background"
2d_render/layer_2="Map"
2d_render/layer_3="Creatures"
2d_render/layer_4="POI"
2d_render/layer_5="UI"

[android]

modules/org/godotengine/godot/GodotPaymentV3.enabled=false
modules/org/godotengine/godot/GodotPaymentV3/whitelist.content=

config/features=PackedStringArray("4.3", "Mobile")
config/icon="res://icon.svg"
config/name="Furlan Go"
config/package="com.friuland.furlango"
config/version="0.1.0"
config/version_name="0.1.0"
config/use_custom_build=true

graphics/opengl3/buffers/hdr=false
graphics/opengl3/buffers/xr=true
shaders/enabled=true
form_factor="0"
anchor_detection_enabled=true
plane_detection_enabled=true
graphics/opengl3/ffx_fsr2_sharpness=0.5
graphics/opengl3/ffx_fsr2_mode=0
graphics/opengl3/tier3/roughness_limiter=0.0

input_devices/pointing/emulate_mouse_from_touch=true
input_devices/pointing/emulate_touch_from_mouse=false

network/tls/certificates=""

rendering/textures/canvas_textures/default_texture_filter=0
